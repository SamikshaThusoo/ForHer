{
  "expo": {
    "name": "ForHer",
    "slug": "forher",
    "owner": "samikshathusoo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.forher.pmos",
      "buildNumber": "1",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow ForHer to recognise speech for voice meal logging.",
        "NSMicrophoneUsageDescription": "Allow ForHer to use the microphone for voice meal logging."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.forher.pmos"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ForHer to use the camera to scan food packets."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow ForHer to use the microphone for voice meal logging.",
          "speechRecognitionPermission": "Allow ForHer to recognise speech for voice meal logging."
        }
      ],
      "expo-splash-screen",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FBF3F5",
          "image": "./assets/splash-icon.png",
          "imageWidth": 180
        }
      ]
    ],
    "scheme": "forher",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "47a4b90f-b542-482c-8804-fce707020590"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/47a4b90f-b542-482c-8804-fce707020590"
    }
  }
}
